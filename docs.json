{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Perflo",
  "description": "Money accounts, cards, trading, and payments for people, businesses, and AI agents.",
  "colors": {
    "primary": "#C25A2B",
    "light": "#E8843C",
    "dark": "#E8843C"
  },
  "favicon": "/favicon.svg",
