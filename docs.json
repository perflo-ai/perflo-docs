        "pages": [
          "introduction",
          "quickstart",
          "getting-started/create-account",
          "getting-started/verify-identity",
          "getting-started/fund-your-account",
          "getting-started/troubleshooting"
        ]
      },
      {
        "group": "Trust and safety",
        "pages": [
          "concepts/how-perflo-works",
          "concepts/guardrails",
          "reference/security",
          "concepts/fees-and-limits"
        ]
      },
      {
        "group": "Your money",
        "pages": [
          "money/cash",
          "money/assets",
          "money/earn",
          "money/borrow"
        ]
      },
      {
        "group": "Trading",
        "pages": [
          "trading/futures",
          "trading/predictions"
        ]
      },
      {
        "group": "Cards and payments",
        "pages": [
          "cards-banking/virtual-cards",
          "cards-banking/bank-accounts",
          "cards-banking/payouts-and-transfers",
          "cards-banking/troubleshooting"
        ]
      },
      {
        "group": "AI agents",
        "pages": [
          "agents/overview",
          "agents/connect",
          "agents/spending-and-budgets",
          "agents/services",
          "agents/security",
          "agents/errors-and-denials",
          "agents/troubleshooting"
        ]
      },
      {
        "group": "Help and reference",
        "pages": [
          "reference/faq",
          "changelog",
          "reference/supported-currencies",
          "reference/networks-and-contracts"
        ]
      }
