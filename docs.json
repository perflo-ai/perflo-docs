  "redirects": [
    {
      "source": "/money/gold",
      "destination": "/money/assets"
    }
  ],
  "footer": {
    "socials": {
      "website": "https://perflo.ai"
    },
    "links": [
      {
        "header": "Help",
        "items": [
          {
            "label": "Contact support",
            "href": "mailto:support@perflo.ai"
          },
          {
